{
  "name": "reframe-cbt",
  "version": "1.0.0",
  "private": true,
  "description": "Reframe — a private, offline-first CBT 7-column thought record. Android-first PWA, Capacitor-ready.",
  "type": "module",
  "scripts": {
    "dev": "npx -y http-server -p 4180 -c-1 -o",
    "icons": "node scripts/generate-icons.mjs",
    "build:web": "node scripts/sync-web.mjs",
    "cap:add:android": "npm run build:web && npx cap add android",
    "cap:sync": "npm run build:web && npx cap sync",
    "cap:open:android": "npx cap open android"
  },
  "keywords": [
    "cbt",
    "thought-record",
    "mental-health",
    "pwa",
    "capacitor",
    "offline"
  ],
  "license": "MIT",
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/assets": "^3.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "sharp": "^0.34.5"
  },
  "optionalNativeDependencies": {
    "_comment": "Install when wrapping for native — see README.",
    "@capacitor/app": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor-community/sqlite": "^6.0.0",
    "capacitor-native-biometric": "^4.2.0"
  },
  "dependencies": {
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/share": "^6.0.4",
    "capacitor-native-biometric": "^4.2.2"
  }
}
