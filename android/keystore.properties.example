# Release signing for Google Play.
#
# 1) Create your upload keystore once (run from the reframe-cbt/ folder):
#      keytool -genkey -v -keystore reframe-release.keystore -alias reframe -keyalg RSA -keysize 2048 -validity 10000
# 2) Copy this file to:  android/keystore.properties
# 3) Fill in the values below.
# 4) NEVER commit keystore.properties or the .keystore file (they're gitignored).
#    Back them up somewhere safe — losing them means you can't update the app.
#
# storeFile is relative to android/app/ — this points at reframe-cbt/reframe-release.keystore
storeFile=../../reframe-release.keystore
storePassword=CHANGE_ME
keyAlias=reframe
keyPassword=CHANGE_ME
